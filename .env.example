# Copy to .env and fill in values.

# Ollama server URL — defaults to the local Docker/Lando Ollama service
OLLAMA_BASE_URL=http://ollama:11434

# Model to use — must be pulled first with: lando pull-model  (or docker compose run ollama ollama pull <model>)
OLLAMA_MODEL=qwen2.5-coder:7b

# Postgres URI for durable LangGraph checkpoints
POSTGRES_URI=postgresql://langgraph:langgraph@postgres:5432/langgraph?sslmode=disable

# Optional checkpoint controls
LANGGRAPH_CHECKPOINTS_ENABLED=true
LANGGRAPH_CHECKPOINTS_AUTO_SETUP=true
