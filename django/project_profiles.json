[
  {
    "id": "workspace",
    "name": "Workspace Sandbox",
    "description": "General-purpose profile for graph exploration and file edits in MCP sandbox.",
    "filesystem_roots": [
      "/workspace-data",
      "/workspace-data/webapps",
      "/workspace-data/shared"
    ],
    "mcp_root": "/workspace-data",
    "default_graph": "basic",
    "allowed_graphs": ["basic", "swarm_v1"],
    "tool_mode": "read_write"
  },
  {
    "id": "webapp-qa",
    "name": "Webapp QA and Optimization",
    "description": "Use swarm graph to test, review, and optimize a target web application workspace.",
    "filesystem_roots": [
      "/workspace-data/webapps/site-a",
      "/workspace-data/webapps/site-b"
    ],
    "mcp_root": "/workspace-data/webapps",
    "default_graph": "swarm_v1",
    "allowed_graphs": ["swarm_v1", "basic"],
    "tool_mode": "read_only"
  }
]
